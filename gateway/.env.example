# LobeHub gateway listen address
LISTEN_ADDR=:8080

# Official LobeHub upstream URL. The gateway reverse-proxies to this service.
LOBEHUB_UPSTREAM_URL=http://lobehub:3210

# Sub2API backend API base URL. Must point at /api/v1.
SUB2API_API_BASE_URL=https://api.example.com/api/v1

# Sub2API frontend URL used for refresh-target redirects.
SUB2API_FRONTEND_URL=https://app.example.com

# Generic OIDC provider id used by official LobeHub.
LOBEHUB_PROVIDER_ID=generic-oidc

# Bootstrap endpoint exposed on the chat domain.
LOBEHUB_BOOTSTRAP_PATH=/__lobehub_bootstrap

# Official LobeHub route used by ConfigProbe to read persisted user settings.
LOBEHUB_USER_STATE_PATH=/trpc/lambda/user.getUserState

# Cache public settings locally inside the gateway.
PUBLIC_SETTINGS_CACHE_TTL=30s
